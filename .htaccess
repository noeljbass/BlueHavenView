# Force a single canonical host/protocol so Google does not see duplicate
# http://, http://www., and https://www. versions of the same pages.
RewriteEngine On

# Normalize duplicate slashes in crawlable page paths before canonical host checks.
RewriteCond %{THE_REQUEST} \s/+(.+)//+([^\s?]*) [NC]
RewriteRule ^ https://bluehavenview.com/%1/%2 [R=301,L,NE]

# Redirect explicit index.html URLs to their directory canonical URLs.
RewriteRule ^index\.html$ https://bluehavenview.com/ [R=301,L]
RewriteRule ^(.+/)index\.html$ https://bluehavenview.com/$1 [R=301,L]

# Redirect plain HTTP to HTTPS, while avoiding redirect loops behind proxies.
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://bluehavenview.com%{REQUEST_URI} [R=301,L]

# Redirect www and any other host aliases to the canonical apex domain.
RewriteCond %{HTTP_HOST} !^bluehavenview\.com$ [NC]
RewriteRule ^ https://bluehavenview.com%{REQUEST_URI} [R=301,L]
